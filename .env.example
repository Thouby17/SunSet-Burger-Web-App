# Copie ce fichier en `.env` puis adapte les valeurs.
# ⚠️ Ne jamais commiter le fichier `.env` réel (déjà exclu par .gitignore).

# --- Base de données ---
# Local (SQLite) :
DATABASE_URL="file:./dev.db"
# Production (Vercel + Neon Postgres) — une base PROPRE à CE client, jamais
# partagée avec un autre projet :
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Mots de passe (staff/admin) ---
STAFF_PASSWORD="change-moi"
ADMIN_PASSWORD="change-moi-aussi"

# --- Web Push (notifications écran verrouillé) ---
# Génère une paire PROPRE à ce client : npx web-push generate-vapid-keys
# Ne JAMAIS réutiliser les clés d'un autre client.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_SUBJECT="mailto:contact@example.com"

# --- Horaires ---
# Absent ou "false" en développement (toujours "ouvert", pratique pour tester).
# "true" en production pour appliquer réellement les horaires du restaurant.
ENFORCE_HOURS="false"
