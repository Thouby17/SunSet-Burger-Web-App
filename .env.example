# Copie ce fichier en `.env` puis adapte les valeurs.

# Base de données PostgreSQL (Neon).
# - En local : colle ici l'URL de connexion Neon (ou une branche de dev).
# - Sur Vercel : définis DATABASE_URL dans les variables d'environnement du projet.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Mot de passe d'accès à l'écran staff (/staff). À CHANGER pour la prod.
STAFF_PASSWORD="change-moi"
